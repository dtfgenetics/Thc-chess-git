# Kush Kings Chess / THC Chess production environment
# Target: dtfseeds.com games hub

APP_NAME="Kush Kings Chess"
NODE_ENV="production"

# Frontend public URL.
# Recommended first deployment: use a subdomain for the socket app and link/embed it from dtfseeds.com.
NEXT_PUBLIC_APP_NAME="Kush Kings Chess"
NEXT_PUBLIC_SITE_URL="https://chess.dtfseeds.com"
NEXT_PUBLIC_API_URL="https://chess-api.dtfseeds.com"

# Backend/server room settings
PORT="3001"
CORS_ORIGIN="https://chess.dtfseeds.com,https://dtfseeds.com,https://www.dtfseeds.com"
SESSION_COOKIE_NAME="kush_kings_chess"
SESSION_COOKIE_DOMAIN=".dtfseeds.com"
SESSION_SECRET="replace-with-a-long-random-secret"

# PostgreSQL game room database
PGHOST="replace-with-postgres-host"
PGPORT="5432"
PGUSER="replace-with-postgres-user"
PGPASSWORD="replace-with-postgres-password"
PGDATABASE="kush_kings_chess"
